# Public hostname pointed to the ECS instance. Caddy provisions HTTPS automatically.
DOMAIN=videowatch.platinexsolutions.com.ng
ACME_EMAIL=ops@example.com

# Django
DJANGO_DEBUG=0
DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_ALLOWED_HOSTS=videowatch.platinexsolutions.com.ng,127.0.0.1,localhost
DJANGO_CSRF_TRUSTED_ORIGINS=https://videowatch.platinexsolutions.com.ng
DJANGO_USE_X_FORWARDED_HOST=1
DJANGO_SECURE_SSL_REDIRECT=1
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=1
DJANGO_SECURE_HSTS_PRELOAD=0

# Use the pooled Neon connection string and retain sslmode=require.
DATABASE_URL=postgresql://user:password@ep-example-pooler.region.aws.neon.tech/neondb?sslmode=require&channel_binding=require
DATABASE_CONN_MAX_AGE=60
DESCRIBEOPS_MEDIA_ROOT=/app/media
DJANGO_STATIC_ROOT=/app/staticfiles

# Server-side service token for trusted extension/admin ingestion calls.
DESCRIBEOPS_API_TOKEN=replace-with-shared-api-token
# Chrome extension auth is enabled by default. Set to 0 only to disable direct extension capture.
DESCRIBEOPS_ALLOW_EXTENSION_AUTH=1
DESCRIBEOPS_ALLOWED_ORIGINS=https://videowatch.platinexsolutions.com.ng
DESCRIBEOPS_MAX_UPLOAD_BYTES=26214400
DESCRIBEOPS_MAX_VIDEO_UPLOAD_BYTES=524288000
# Optional: mount host secrets at /app/secrets and read authorized yt-dlp cookies from there.
DESCRIBEOPS_SECRETS_DIR=./secrets
DESCRIBEOPS_YTDLP_COOKIE_FILE=/app/secrets/youtube-cookies.txt
VITE_API_BASE_URL=
# Leave blank for the public web app. Users authenticate with account tokens at runtime.
VITE_API_TOKEN=

# Container log viewer at /logs/. Generate the hash with:
# docker run --rm caddy:2-alpine caddy hash-password --plaintext 'replace-with-strong-password'
LOGS_BASIC_AUTH_USER=logs
LOGS_BASIC_AUTH_HASH='$2a$14$replace-with-caddy-bcrypt-hash'

# Alibaba Model Studio / Qwen
DASHSCOPE_API_KEY=replace-with-alibaba-model-studio-key
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_VISUAL_MODEL=qwen3.6-flash
QWEN_TEXT_MODEL=qwen3.6-flash
QWEN_JUDGE_MODEL=qwen3.6-plus
QWEN_FINAL_MODEL=qwen3.7-max
ALIBABA_CLOUD_DEPLOYMENT=ecs-compose
