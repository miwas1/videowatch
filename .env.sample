# DescribeOps deployment sample
# Copy to .env.local for local development or map these values in your cloud runtime.

# Server-only secrets. Never expose these with a VITE_ prefix.
DESCRIBEOPS_API_TOKEN=replace-with-random-bearer-token
DASHSCOPE_API_KEY=replace-with-qwen-cloud-key
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Alibaba Cloud runtime marker shown by /health without leaking secrets.
ALIBABA_CLOUD_DEPLOYMENT=local

# API guardrails.
DESCRIBEOPS_MAX_UPLOAD_BYTES=26214400
DESCRIBEOPS_ALLOWED_ORIGINS=https://describeops.example.com

# Qwen model routing overrides.
QWEN_TEXT_MODEL=qwen-max-latest
QWEN_MULTIMODAL_MODEL=qwen3.6-flash
QWEN_OCR_MODEL=qwen3.6-flash
QWEN_QA_MODEL=qwen-max-latest
QWEN_SUMMARY_MODEL=qwen-plus-latest

# Public frontend values only. Vite bundles VITE_* values into client assets.
VITE_DESCRIBEOPS_API_BASE_URL=https://api.describeops.example.com
VITE_DESCRIBEOPS_RELEASE_BASE_URL=https://github.com/describeops/describeops/releases/latest/download
VITE_DESCRIBEOPS_EXTENSION_ZIP=describeops-extension.zip
VITE_DESCRIBEOPS_COMPANION_WINDOWS=describeops-companion-windows-x64.msi
VITE_DESCRIBEOPS_COMPANION_MACOS=describeops-companion-macos-universal.dmg
VITE_DESCRIBEOPS_COMPANION_LINUX=describeops-companion-linux-x64.AppImage
