DJANGO_DEBUG=0
DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_ALLOWED_HOSTS=api.example.com,backend-public-ip-or-internal-host
DJANGO_CSRF_TRUSTED_ORIGINS=https://api.example.com
DJANGO_USE_X_FORWARDED_HOST=1
DJANGO_SECURE_SSL_REDIRECT=1
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=1
DJANGO_SECURE_HSTS_PRELOAD=0

DATABASE_URL=postgresql://describeops:replace-password@replace-rds-host:5432/describeops
DESCRIBEOPS_MEDIA_ROOT=/var/lib/describeops/media

DESCRIBEOPS_API_TOKEN=replace-with-shared-api-token
DESCRIBEOPS_ALLOWED_ORIGINS=https://www.example.com,https://example.com
DESCRIBEOPS_MAX_UPLOAD_BYTES=26214400

DASHSCOPE_API_KEY=replace-with-alibaba-model-studio-key
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_VISUAL_MODEL=qwen3.6-flash
QWEN_TEXT_MODEL=qwen3.6-flash
QWEN_JUDGE_MODEL=qwen3.6-plus
QWEN_FINAL_MODEL=qwen3.7-max

ALIBABA_CLOUD_DEPLOYMENT=ecs
