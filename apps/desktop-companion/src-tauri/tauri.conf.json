{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DescribeOps Companion",
  "version": "0.1.0",
  "identifier": "com.describeops.companion",
  "build": {
    "beforeDevCommand": "npm run dev:ui",
    "beforeBuildCommand": "npm run build:ui",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "DescribeOps Companion",
        "width": 900,
        "height": 680
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
