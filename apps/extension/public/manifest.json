{
  "manifest_version": 3,
  "name": "DescribeOps",
  "description": "Qwen-powered accessibility browser agent for video and web content.",
  "version": "0.1.0",
  "minimum_chrome_version": "116",
  "action": {
    "default_title": "DescribeOps",
    "default_popup": "popup.html"
  },
  "commands": {
    "describe-current-state": {
      "suggested_key": {
        "default": "Alt+Shift+D"
      },
      "description": "Describe the current video moment"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*", "file:///*"],
      "js": ["content-script.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "permissions": ["activeTab", "nativeMessaging", "offscreen", "sidePanel", "scripting", "storage", "tabCapture"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "optional_host_permissions": ["file:///*"],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
