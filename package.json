{
  "name": "describeops",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "license": "Apache-2.0",
  "workspaces": ["apps/extension", "apps/web"],
  "scripts": {
    "build": "vite build apps/extension",
    "build:extension": "vite build apps/extension",
    "build:web": "npm run package:extension && npm run build -w @describeops/web",
    "dev:web": "npm run dev -w @describeops/web",
    "package:extension": "npm run build:extension && node scripts/package-extension.mjs",
    "typecheck": "tsc -p apps/extension/tsconfig.json --noEmit",
    "typecheck:web": "tsc -p apps/web/tsconfig.json --noEmit",
    "test": "npm run test:web",
    "test:web": "npm run test -w @describeops/web",
    "test:backend": "cd backend && uv run --no-cache pytest",
    "verify": "npm run typecheck && npm run typecheck:web && npm run test:web && npm run test:backend && npm run build:extension && npm run build:web"
  },
  "dependencies": {
    "@radix-ui/react-icons": "^1.3.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "typescript": "^5.9.0",
    "vite": "^7.0.0",
    "vitest": "^4.0.0"
  }
}
